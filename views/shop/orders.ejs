<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('../includes/head.ejs') %>
  </head>
  <body>
    <%- include('../includes/nav.ejs') %>

    <main>

      <% if(orders.lengthb <= 0){ %>
        <h1>Order</h1>
      <% } else { %>
        <ul>
          <% orders.forEach(order=> { %>
            <li>
              <h1># <%= order.id %></h1>

              <ul>
                <% order.products.forEach(product=> { %>
                  <li><%= product.title %> (<%= product.quantity %>)</li>
                <% }) %>  
              </ul>
            
            </li>
          <% });%>
        </ul>

      <% } %>
    </main>
  </body>
</html>
